# ──────────────────────────────────────────────────────────────────────────────
# .env — корневой файл переменных окружения для docker-compose
# ВАЖНО: добавь этот файл в .gitignore!
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=nota
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=nota

# ── NestJS Backend ────────────────────────────────────────────────────────────
NODE_ENV=production

# Домен кук (для production — твой домен, например: example.com)
COOKIE_DOMAIN=YOUR_DOMAIN

# JWT — сгенерируй командой: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=7d

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/core/prisma/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  login        String   @unique @db.Text
  passwordHash String?  @map("password_hash") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  streams Stream[]
  notes   Note[]

  @@map("users")
}

model Stream {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.Text
  normalizedName String   @map("normalized_name") @db.Text
  fromMessageId  String?  @map("from_message_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromMessage Message?     @relation(fields: [fromMessageId], references: [id], onDelete: SetNull)
  noteStreams NoteStream[]
  chats       Chat[]

  @@unique([userId, normalizedName], map: "streams_user_id_normalized_name_uq")
  @@index([userId], map: "streams_user_id_idx")
  @@map("streams")
}

model Chat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  streamId  String?  @map("stream_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  stream   Stream?   @relation(fields: [streamId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("chats")
}

model Message {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chatId       String   @map("chat_id") @db.Uuid
  bodyMarkdown String   @map("body_markdown") @db.Text
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  chat    Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  streams Stream[]
  notes   Note[]

  @@index([chatId, createdAt], map: "messages_chat_id_created_at_idx")
  @@map("messages")
}

model Note {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String                   @map("user_id") @db.Uuid
  bodyMarkdown  String                   @map("body_markdown") @db.Text
  bodyText      String                   @map("body_text") @db.Text
  previewText   String                   @map("preview_text") @db.Text
  searchVector  Unsupported("tsvector")? @map("search_vector")
  fromMessageId String?                  @map("from_message_id") @db.Uuid
  createdAt     DateTime                 @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(3)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromMessage Message?     @relation(fields: [fromMessageId], references: [id], onDelete: SetNull)
  noteStreams NoteStream[]

  @@index([userId, updatedAt(sort: Desc)], map: "notes_user_id_updated_at_idx")
  @@map("notes")
}

model NoteStream {
  noteId    String   @map("note_id") @db.Uuid
  streamId  String   @map("stream_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  stream Stream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@id([noteId, streamId], map: "note_streams_pkey")
  @@index([streamId, noteId], map: "note_streams_stream_id_note_id_idx")
  @@map("note_streams")
}
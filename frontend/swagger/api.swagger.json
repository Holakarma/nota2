	"info": {
		"title": "Nota API",
		"description": "Nota backend API",
		"version": "1.0",
		"contact": {}
	},
	"tags": [],
	"servers": [],
	"components": {
		"securitySchemes": {
			"bearer": {
				"scheme": "bearer",
				"bearerFormat": "JWT",
				"type": "http"
			}
		},
		"schemas": {
			"SignUpRequestDto": {
				"type": "object",
				"properties": {
					"login": {
						"type": "string",
						"description": "User login",
						"example": "user-login",
						"minLength": 8,
						"maxLength": 255
					},
					"password": {
						"type": "string",
						"description": "User password",
						"example": "strong-password",
						"minLength": 8,
						"maxLength": 128
					}
				},
				"required": ["login", "password"]
			},
			"AuthResponse": {
				"type": "object",
				"properties": {
					"accessToken": {
						"type": "string",
						"description": "JWT access token",
						"example": "etrf7AG7iFA78FAdsfaF..."
					}
				},
				"required": ["accessToken"]
			},
			"SignInRequestDto": {
				"type": "object",
				"properties": {
					"login": {
						"type": "string",
						"description": "User login",
						"example": "user-login",
						"minLength": 8,
						"maxLength": 255
					},
					"password": {
						"type": "string",
						"description": "User password",
						"example": "strong-password",
						"minLength": 8,
						"maxLength": 128
					}
				},
				"required": ["login", "password"]
			},
			"StreamResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "1a6b43f3-d064-4e83-a9ec-fba73453a49c"
					},
					"userId": {
						"type": "string",
						"format": "uuid",
						"example": "cecb38fb-dc6b-4b5f-9cf7-e733dbadbe7e"
					},
					"name": {
						"type": "string",
						"example": "work"
					},
					"normalizedName": {
						"type": "string",
						"example": "work"
					},
					"createdAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					},
					"updatedAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					}
				},
				"required": [
					"id",
					"userId",
					"name",
					"normalizedName",
					"createdAt",
					"updatedAt"
				]
			},
			"FindSimilarStreamsDto": {
				"type": "object",
				"properties": {
					"query": {
						"type": "string",
						"description": "Text used to find the closest streams by name",
						"minLength": 1,
						"maxLength": 500,
						"example": "work projects"
					},
					"limit": {
						"type": "object",
						"description": "Maximum number of similar streams to return",
						"minimum": 2,
						"maximum": 100,
						"default": 5,
						"example": 5
					}
				},
				"required": ["query"]
			},
			"CreateStreamDto": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"description": "stream name",
						"example": "work",
						"minLength": 1,
						"maxLength": 128
					}
				},
				"required": ["name"]
			},
			"UpdateStreamDto": {
				"type": "object",
				"properties": {
					"name": {
						"type": "string",
						"description": "stream new name",
						"example": "personal",
						"minLength": 1,
						"maxLength": 128
					}
				},
				"required": ["name"]
			},
			"NoteListStreamResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "1a6b43f3-d064-4e83-a9ec-fba73453a49c"
					},
					"name": {
						"type": "string",
						"example": "work"
					}
				},
				"required": ["id", "name"]
			},
			"NoteWithStreamsResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "8e2d5c9a-2b19-4d2f-9a4e-7d1c2f6a9b10"
					},
					"previewText": {
						"type": "string",
						"example": "new note"
					},
					"streams": {
						"description": "streams linked with this note",
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/NoteListStreamResponseDto"
						}
					},
					"updatedAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					},
					"createdAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					}
				},
				"required": [
					"id",
					"previewText",
					"streams",
					"updatedAt",
					"createdAt"
				]
			},
			"NoteSourceType": {
				"type": "string",
				"enum": ["WEB", "TELEGRAM"]
			},
			"NoteResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "8e2d5c9a-2b19-4d2f-9a4e-7d1c2f6a9b10"
					},
					"userId": {
						"type": "string",
						"format": "uuid",
						"example": "cecb38fb-dc6b-4b5f-9cf7-e733dbadbe7e"
					},
					"bodyMarkdown": {
						"type": "string",
						"example": "new note"
					},
					"bodyText": {
						"type": "string",
						"example": "new note"
					},
					"previewText": {
						"type": "string",
						"example": "new note"
					},
					"streams": {
						"description": "streams linked with this note",
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/NoteListStreamResponseDto"
						}
					},
					"sourceType": {
						"example": "WEB",
						"allOf": [
							{
								"$ref": "#/components/schemas/NoteSourceType"
							}
						]
					},
					"sourceMeta": {
						"type": "object",
						"additionalProperties": true,
						"example": {}
					},
					"createdAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					},
					"updatedAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-04-29T10:00:00.000Z"
					},
					"deletedAt": {
						"type": "object",
						"format": "date-time",
						"nullable": true,
						"example": null
					},
					"sourceMessageId": {
						"type": "object",
						"format": "uuid",
						"nullable": true,
						"example": "5e6ab56f-205c-4fd1-9d6b-bdddfb816c39"
					}
				},
				"required": [
					"id",
					"userId",
					"bodyMarkdown",
					"bodyText",
					"previewText",
					"streams",
					"sourceType",
					"sourceMeta",
					"createdAt",
					"updatedAt"
				]
			},
			"FindSimilarNotesDto": {
				"type": "object",
				"properties": {
					"query": {
						"type": "string",
						"description": "Text used to find the closest notes by content",
						"minLength": 1,
						"maxLength": 500,
						"example": "meeting notes about project deadlines"
					},
					"limit": {
						"type": "object",
						"description": "Maximum number of similar notes to return",
						"minimum": 2,
						"maximum": 100,
						"default": 5,
						"example": 5
					}
				},
				"required": ["query"]
			},
			"CreateNoteDto": {
				"type": "object",
				"properties": {
					"bodyMarkdown": {
						"type": "string",
						"description": "note content",
						"example": "new note",
						"minLength": 1,
						"maxLength": 32768
					},
					"streamIds": {
						"description": "existing stream ids to link with this note",
						"maxItems": 20,
						"example": ["1a6b43f3-d064-4e83-a9ec-fba73453a49c"],
						"type": "array",
						"items": {
							"type": "string",
							"format": "uuid"
						}
					}
				},
				"required": ["bodyMarkdown"]
			},
			"UpdateNoteDto": {
				"type": "object",
				"properties": {
					"bodyMarkdown": {
						"type": "string",
						"description": "note new content",
						"example": "note new content",
						"minLength": 1,
						"maxLength": 32768
					}
				},
				"required": ["bodyMarkdown"]
			},
			"ChatResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "2d203a13-3e78-4fcb-a31d-6dcbdf9ec88e"
					},
					"userId": {
						"type": "string",
						"format": "uuid",
						"example": "cecb38fb-dc6b-4b5f-9cf7-e733dbadbe7e"
					},
					"streamId": {
						"type": "object",
						"format": "uuid",
						"nullable": true,
						"example": "1a6b43f3-d064-4e83-a9ec-fba73453a49c"
					},
					"createdAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-05-03T10:00:00.000Z"
					},
					"updatedAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-05-03T10:00:00.000Z"
					}
				},
				"required": ["id", "userId", "createdAt", "updatedAt"]
			},
			"ChatMessageRole": {
				"type": "string",
				"enum": ["USER", "SYSTEM"]
			},
			"ChatMessageResultNoteResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "8e2d5c9a-2b19-4d2f-9a4e-7d1c2f6a9b10"
					},
					"previewText": {
						"type": "string",
						"description": "markdown-stripped preview text of the created note",
						"example": "Need to follow up with Alex tomorrow"
					},
					"streamNames": {
						"description": "names of all streams linked to the created note",
						"example": ["work"],
						"type": "array",
						"items": {
							"type": "string"
						}
					}
				},
				"required": ["id", "previewText", "streamNames"]
			},
			"ChatMessageStreamResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "1a6b43f3-d064-4e83-a9ec-fba73453a49c"
					},
					"name": {
						"type": "string",
						"example": "work"
					}
				},
				"required": ["id", "name"]
			},
			"ChatMessageResultResponseDto": {
				"type": "object",
				"properties": {
					"note": {
						"description": "note created from this message",
						"nullable": true,
						"type": "object",
						"allOf": [
							{
								"$ref": "#/components/schemas/ChatMessageResultNoteResponseDto"
							}
						]
					},
					"streams": {
						"description": "streams newly created while processing this message",
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/ChatMessageStreamResponseDto"
						}
					}
				},
				"required": ["note", "streams"]
			},
			"ChatMessageResponseDto": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"example": "5e6ab56f-205c-4fd1-9d6b-bdddfb816c39"
					},
					"chatId": {
						"type": "string",
						"format": "uuid",
						"example": "2d203a13-3e78-4fcb-a31d-6dcbdf9ec88e"
					},
					"role": {
						"example": "USER",
						"allOf": [
							{
								"$ref": "#/components/schemas/ChatMessageRole"
							}
						]
					},
					"bodyMarkdown": {
						"type": "string",
						"description": "original user message markdown",
						"example": ":work\nNeed to follow up with Alex tomorrow"
					},
					"replyToMessageId": {
						"type": "object",
						"format": "uuid",
						"nullable": true,
						"example": null
					},
					"result": {
						"description": "message processing result",
						"nullable": true,
						"type": "object",
						"allOf": [
							{
								"$ref": "#/components/schemas/ChatMessageResultResponseDto"
							}
						]
					},
					"createdAt": {
						"format": "date-time",
						"type": "string",
						"example": "2026-05-03T10:00:00.000Z"
					}
				},
				"required": [
					"id",
					"chatId",
					"role",
					"bodyMarkdown",
					"result",
					"createdAt"
				]
			},
			"CreateChatDto": {
				"type": "object",
				"properties": {
					"streamId": {
						"type": "string",
						"description": "existing stream id to bind this chat to",
						"format": "uuid",
						"example": "1a6b43f3-d064-4e83-a9ec-fba73453a49c"
					}
				}
			},
			"CreateChatMessageDto": {
				"type": "object",
				"properties": {
					"bodyMarkdown": {
						"type": "string",
						"description": "Full user message markdown. Non-blank leading and trailing lines that start with \":\" are parsed as stream names and excluded from the created note body.",
						"example": ":work\nNeed to follow up with Alex tomorrow",
						"minLength": 1,
						"maxLength": 32768
					}
				},
				"required": ["bodyMarkdown"]
			}
		}
	}
}
